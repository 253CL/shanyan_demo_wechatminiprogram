.container {
  min-height: 100vh;
  box-sizing: border-box;
  background: #f5f5f5;
}

.navbar {
  width: 100%;
  background: transparent;
}

.navbar-fixed {
  position: fixed;
  left: 0;
  right: 0;
  z-index: 1;
  background: transparent;
}

.navbar-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  padding: 0 24rpx;
}

.navbar-back {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  font-size: 60rpx;
  color: #333;
  line-height: 1;
}

.navbar-title {
  flex: 1;
  text-align: center;
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
}

.navbar-placeholder {
  width: 60rpx;
}

.navbar-spacer {
  width: 100%;
}

.banner {
  width: 100%;
  height: 300rpx;
  border-radius: 16rpx;
  margin-bottom: 60rpx;
}

.btn-row {
  width: 100%;
  display: flex;
  gap: 24rpx;
  padding: 0 30rpx;
  margin-bottom: 24rpx;
  box-sizing: border-box;
}

.btn-row:last-child {
  margin-bottom: 0;
}

.mode-card {
  flex: 1;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 16rpx;
  padding: 40rpx 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.mode-card:active {
  opacity: 0.7;
}

.card-icon {
  width: 80rpx;
  height: 80rpx;
  margin-bottom: 24rpx;
}

.card-title {
  font-size: 26rpx;
  color: #333;
  font-weight: 600;
  text-align: center;
  line-height: 1.4;
}
