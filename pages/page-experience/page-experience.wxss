.container {
  min-height: 100vh;
  background: #f5f5f5;
}

.navbar {
  width: 100%;
  background: #2b7de0;
}

.navbar-fixed {
  position: fixed;
  left: 0;
  right: 0;
  z-index: 999;
  background: #2b7de0;
}

.navbar-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  padding: 0 24rpx;
}

.navbar-back {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  font-size: 60rpx;
  color: #fff;
  line-height: 1;
}

.navbar-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #fff;
}

.navbar-placeholder {
  width: 60rpx;
}

.navbar-spacer {
  width: 100%;
}

.btn-wrapper {
  padding: 60rpx 40rpx;
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

.mode-btn {
  background: #2b7de0;
  color: #fff;
  border-radius: 16rpx;
  padding: 36rpx 0;
  text-align: center;
}

.mode-btn:active {
  opacity: 0.8;
}

.btn-label {
  font-size: 32rpx;
  font-weight: 500;
}
