<view class="container">
  <!-- 自定义导航栏 -->
  <view class="navbar" style="height: {{statusBarHeight}}px;"></view>
  <view class="navbar-fixed" style="top: {{statusBarHeight}}px;">
    <view class="navbar-content">
      <view class="navbar-back" bindtap="onGoBack">
        <text class="back-icon">‹</text>
      </view>
      <text class="navbar-title">体验模式</text>
      <view class="navbar-placeholder"></view>
    </view>
  </view>
  <view class="navbar-spacer" style="height: {{statusBarHeight + 44}}px;"></view>

  <!-- 一键登录授权页组件（插件） -->
  <onekeylogin />

  <!-- Logo，参考首页 banner 位置 -->
  <image class="banner" src="/images/login_demo_experience_logo.png" mode="aspectFit"></image>

  <!-- 四个按钮 2x2 排列 -->
  <view class="btn-row">
    <view class="mode-card" bindtap="onStandardStyle">
      <image class="card-icon" src="/images/login_demo_4.png" mode="aspectFit"></image>
      <text class="card-title">默认弹窗样式</text>
    </view>
    <view class="mode-card" bindtap="onCustomStyle">
      <image class="card-icon" src="/images/login_demo_2.png" mode="aspectFit"></image>
      <text class="card-title">全屏样式</text>
    </view>
  </view>
  <view class="btn-row">
    <view class="mode-card" bindtap="onCustomStyle1">
      <image class="card-icon" src="/images/login_demo_3.png" mode="aspectFit"></image>
      <text class="card-title">自定义弹窗样式1</text>
    </view>
    <view class="mode-card" bindtap="onCustomStyle2">
      <image class="card-icon" src="/images/login_demo_1.png" mode="aspectFit"></image>
      <text class="card-title">自定义弹窗样式2</text>
    </view>
  </view>
</view>