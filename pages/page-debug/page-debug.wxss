.container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f5f5f5;
  padding-bottom: 150rpx;
  box-sizing: border-box;
}

.navbar {
  width: 100%;
  background: transparent;
}

.navbar-fixed {
  position: fixed;
  left: 0;
  right: 0;
  z-index: 1;
  background: transparent;
}

.navbar-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  padding: 0 24rpx;
}

.navbar-back {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  font-size: 60rpx;
  color: #333;
  line-height: 1;
}

.navbar-title {
  flex: 1;
  text-align: center;
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
}

.navbar-placeholder {
  width: 60rpx;
}

.navbar-spacer {
  width: 100%;
}

.header {
  text-align: center;
  padding: 30rpx 30rpx 30rpx;
  margin-bottom: 20rpx;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  display: block;
}

.subtitle {
  font-size: 24rpx;
  color: #999;
  margin-top: 10rpx;
  display: block;
}

.env-row {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 16rpx;
  margin-top: 8rpx;
}

.env-badge {
  font-size: 22rpx;
  color: #2b7de0;
  background: rgba(232, 240, 251, 0.85);
  border-radius: 6rpx;
  padding: 4rpx 12rpx;
}

.btn-group {
  padding: 0 30rpx;
  margin-top: auto;
  margin-bottom: 50rpx;
}

.step-btn {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: rgba(43, 125, 224, 0.9);
  color: #fff;
  padding: 24rpx 30rpx;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
  transition: all 0.2s;
}

.step-btn.disabled {
  background: #ccc;
  opacity: 0.5;
}

.step-btn.done {
  background: rgba(76, 175, 80, 0.9);
}

.btn-text {
  font-size: 30rpx;
  font-weight: 500;
}

.btn-status {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.results {
  margin: 0 30rpx;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 12rpx;
  padding: 20rpx;
}

.result-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 15rpx;
}

.result-item {
  display: flex;
  flex-direction: column;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.result-item:last-child {
  border-bottom: none;
}

.result-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 5rpx;
}

.result-value {
  font-size: 26rpx;
  color: #333;
  word-break: break-all;
}

.token-text {
  font-size: 22rpx;
  color: #2b7de0;
  margin-top: 5rpx;
}

.log-container {
  margin-left: 30rpx;
  margin-right: 30rpx;
  background: rgba(30, 30, 30, 0.9);
  border-radius: 12rpx;
  overflow: hidden;
}

.log-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 15rpx 20rpx;
  background: rgba(51, 51, 51, 0.9);
}

.log-title {
  font-size: 26rpx;
  color: #fff;
  font-weight: bold;
}

.log-clear {
  font-size: 22rpx;
  color: #4caf50;
}

.log-scroll {
  height: 500rpx;
}

.log-item {
  display: flex;
  padding: 8rpx 20rpx;
  border-bottom: 1rpx solid #2a2a2a;
}

.log-item.error {
  background: #2a1a1a;
}

.log-time {
  font-size: 20rpx;
  color: #888;
  margin-right: 15rpx;
  flex-shrink: 0;
}

.log-message {
  font-size: 24rpx;
  color: #e0e0e0;
  flex: 1;
  word-break: break-all;
}

.log-empty {
  padding: 40rpx 20rpx;
  text-align: center;
  color: #666;
  font-size: 24rpx;
}
