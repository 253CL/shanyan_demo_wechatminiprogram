/* ========== 页面容器 ========== */
.container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-sizing: border-box;
  background: #f5f5f5;
}

/* ========== 自定义导航栏 ========== */
.navbar {
  width: 100%;
  background: transparent;
}

.navbar-fixed {
  position: fixed;
  left: 0;
  right: 0;
  z-index: 1;
  background: transparent;
}

.navbar-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  padding: 0 24rpx;
}

.navbar-placeholder {
  width: 60rpx;
}

.navbar-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
}

.navbar-spacer {
  width: 100%;
}

/* ========== 顶部 Banner ========== */
.banner {
  width: 100%;
  border-radius: 16rpx;
  margin-bottom: 60rpx;
}

/* ========== 按钮行 ========== */
.btn-row {
  width: 100%;
  display: flex;
  justify-content: center;
  gap: 24rpx;
  padding: 50rpx 30rpx 40rpx;
  box-sizing: border-box;
}

/* ========== 模式卡片 ========== */
.mode-card {
  width: 45%;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 16rpx;
  padding: 40rpx 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.mode-card:active {
  opacity: 0.7;
}

.card-icon {
  width: 140rpx;
  height: 140rpx;
  margin-bottom: 24rpx;
}

.card-title {
  font-size: 30rpx;
  color: #333;
  font-weight: 600;
}

/* ========== 结果展示区 ========== */
.result-area {
  width: 100%;
  padding: 0 30rpx;
  box-sizing: border-box;
}

.result-card {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 16rpx;
  padding: 30rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.result-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.result-ticket {
  font-size: 24rpx;
  color: #999;
  word-break: break-all;
}

.result-server {
  font-size: 28rpx;
  color: #2b7de0;
  font-weight: 500;
}
