<view class="container">
  <!-- 自定义导航栏 -->
  <view class="navbar" style="height: {{statusBarHeight}}px;"></view>
  <view class="navbar-fixed" style="top: {{statusBarHeight}}px;">
    <view class="navbar-content">
      <view class="navbar-placeholder"></view>
      <view class="navbar-placeholder"></view>
    </view>
  </view>
  <view class="navbar-spacer" style="height: {{statusBarHeight + 44}}px;"></view>

  <!-- 顶部 banner -->
  <image class="banner" src="/images/captcha_logo.png" mode="widthFix"></image>

  <!-- 验证码触发按钮 -->
  <view class="btn-row">
    <view class="mode-card" bindtap="onShowCaptcha">
      <image class="card-icon" src="/images/captcha_button_logo.png" mode="aspectFit"></image>
      <text class="card-title">点击体验</text>
    </view>
  </view>

  <!-- 验证码插件组件（隐藏，通过代码调用显示） -->
  <t-captcha
    id="captcha"
    app-id="{{captchaAppId}}"
    bindverify="handlerVerify"
    bindready="handlerReady"
    bindclose="handlerClose"
    binderror="handlerError"
  />

  <!-- 隐私政策弹窗 -->
  <privacy-modal id="privacyModal" />
</view>
