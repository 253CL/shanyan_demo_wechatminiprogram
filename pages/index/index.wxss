.container {
  min-height: 100vh;
  background: url('/images/login_demo_bg.png') no-repeat center top;
  background-size: 100% auto;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-sizing: border-box;
}

.navbar {
  width: 100%;
  background: transparent;
}

.navbar-fixed {
  position: fixed;
  left: 0;
  right: 0;
  z-index: 999;
  background: transparent;
}

.navbar-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  padding: 0 24rpx;
}

.navbar-placeholder {
  width: 60rpx;
}

.navbar-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #fff;
}

.navbar-spacer {
  width: 100%;
}

.banner {
  width: 100%;
  border-radius: 16rpx;
  margin-bottom: 60rpx;
}

.btn-row {
  width: 100%;
  display: flex;
  gap: 24rpx;
  padding: 160rpx 30rpx 40rpx;
  box-sizing: border-box;
}

.mode-card {
  flex: 1;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 16rpx;
  padding: 40rpx 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.mode-card:active {
  opacity: 0.7;
}

.card-icon {
  width: 140rpx;
  height: 140rpx;
  margin-bottom: 24rpx;
}

.card-title {
  font-size: 30rpx;
  color: #333;
  font-weight: 600;
}
