.container {
  min-height: 100vh;
  background: #f5f5f5;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 200rpx 30rpx 40rpx;
  box-sizing: border-box;
}

.banner {
  width: 100%;
  border-radius: 16rpx;
  margin-bottom: 60rpx;
}

.btn-row {
  width: 100%;
  display: flex;
  gap: 24rpx;
}

.mode-card {
  flex: 1;
  background: #fff;
  border-radius: 16rpx;
  padding: 40rpx 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.mode-card:active {
  opacity: 0.7;
}

.card-icon {
  width: 140rpx;
  height: 140rpx;
  margin-bottom: 24rpx;
}

.card-title {
  font-size: 30rpx;
  color: #333;
  font-weight: 600;
}
