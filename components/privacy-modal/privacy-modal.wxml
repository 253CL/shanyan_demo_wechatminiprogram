<view class="modal-overlay" wx:if="{{visible}}" catchtap="onDisagree">
  <view class="modal-content" catchtap="stopPropagation">
    <view class="modal-title">隐私政策提示</view>
    <view class="modal-body">
      <text class="modal-text">欢迎您使用闪验小程序。在您使用本小程序服务之前，请认真阅读并充分理解 <text class="modal-link" catchtap="onReadService">《用户服务协议》</text> 和 <text class="modal-link" catchtap="onReadPrivacy">《隐私政策》</text>。</text>
      <text class="modal-text">
        我们将严格按照相关法律法规的要求保护您的个人信息安全。点击"同意并继续"即表示您已阅读并同意上述协议。
      </text>
    </view>
    <view class="modal-actions">
      <view class="btn-disagree" bindtap="onDisagree">
        <text>不同意并退出</text>
      </view>
      <view class="btn-agree" bindtap="onAgree">
        <text>同意并继续</text>
      </view>
    </view>
  </view>
</view>
