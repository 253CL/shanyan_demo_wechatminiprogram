.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 10000;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-content {
  width: 600rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 48rpx 40rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 28rpx;
}

.modal-body {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 36rpx;
}

.modal-text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.7;
  text-align: justify;
}

.modal-link {
  color: #2b7de0;
  font-weight: 500;
}

.modal-actions {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.btn-agree {
  width: 100%;
  height: 84rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #2b7de0;
  border-radius: 42rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #fff;
}

.btn-agree:active {
  opacity: 0.8;
}

.btn-disagree {
  width: 100%;
  height: 84rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: transparent;
  border-radius: 42rpx;
  font-size: 30rpx;
  color: #999;
}

.btn-disagree:active {
  opacity: 0.6;
}
